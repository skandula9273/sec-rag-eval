# Copy to .env and fill in. Never commit .env.

# --- V0 required ---
# OpenAI: embeddings (text-embedding-3-small)
OPENAI_API_KEY=

# Anthropic: generation (Claude Haiku)
ANTHROPIC_API_KEY=

# Neon Postgres + pgvector connection string (use the pooled connection string).
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

